Table CIA_FORNECEDOR {
  ID_FORNECEDOR NUMBER(10) [pk, not null]
  NOME_FORNECEDOR VARCHAR2(200_CHAR) [not null]
  indexes { (NOME_FORNECEDOR) [unique, name: "UK_CIA_FORNECEDOR_NOME"] }
}

Table CIA_RESULTADO {
  ID_RESULTADO NUMBER(10) [pk, not null]
  DATA_CRIACAO TIMESTAMP(3) [not null]
  INFO_RESULTADO CLOB [not null]
  ID_BANCO_QUESTAO NUMBER(10)
  ID_MODELO NUMBER(10)
  TIPO_RESULTADO VARCHAR2(2_CHAR) [not null]
  INDI_ERRO VARCHAR2(1_CHAR) [not null]
  INFO_ERRO CLOB
  QTDE_TOTAL_TOKEN NUMBER(10) [not null]
  QTDE_TOKEN_INPUT NUMBER(10) [not null]
  QTDE_TOKEN_OUTPUT NUMBER(10) [not null]
  indexes { (ID_BANCO_QUESTAO, ID_MODELO) [unique, name: "IDX_CIA_RESULTADO_BANCO_MODELO"] }
}

Table CIA_PERMISSAO_FUNCIONALIDADE {
  TIPO_PERFIL VARCHAR2(2_CHAR) [pk, not null]
  CHAVE_FUNCIONALIDADE VARCHAR2(200_CHAR) [pk, not null]
  INDI_HABILITADO VARCHAR2(1_CHAR) [not null]
  DATA_CRIACAO TIMESTAMP [not null]
  DATA_ATUALIZACAO TIMESTAMP [not null]
}

Table CIA_USUARIO {
  ID_USUARIO NUMBER(10) [pk, not null]
  NOME_USUARIO VARCHAR2(200_CHAR) [not null]
  DESC_EMAIL VARCHAR2(200_CHAR) [not null]
  CODG_USUARIO VARCHAR2(32_CHAR)
  TIPO_PERFIL VARCHAR2(2_CHAR) [not null]
  NOME_ORGAO VARCHAR2(200_CHAR) [not null]
  URL_AVATAR VARCHAR2(500_CHAR)
  INDI_ATIVO VARCHAR2(1_CHAR) [not null]
  DATA_CRIACAO TIMESTAMP [not null]
  DATA_ATUALIZACAO TIMESTAMP [not null]
  HASH_SENHA VARCHAR2(255_CHAR)
  indexes { (DESC_EMAIL) [unique, name: "UK_CIA_USUARIO_EMAIL"] }
}

